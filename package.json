{
  "name": "github-action-standalone-stats",
  "version": "1.0.0",
  "description": "GitHub Action that publishes Allure test reports to a parallel branch of your repo for self-contained pretty charts, trend graphs, and a README badge — no third-party service required.",
  "private": true,
  "type": "module",
  "author": "Cameron Tacklind <cameron@tacklind.com>",
  "license": "MIT",
  "keywords": [
    "github-actions",
    "allure",
    "test-report",
    "stats",
    "gh-pages"
  ],
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "build": "bun build src/main.ts --target=node --format=cjs --outfile=dist/index.js",
    "lint": "tsc --noEmit",
    "test": "bun test src --timeout 30000",
    "format": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cinderblock/github-action-standalone-stats.git"
  },
  "dependencies": {
    "@actions/core": "^3.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^22.19.19",
    "prettier": "^3.5.0",
    "typescript": "^6.0.3"
  }
}
